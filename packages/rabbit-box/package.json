{
  "name": "@rabbitbox/box",
  "version": "0.0.1",
  "description": "In-memory RabbitMQ (AMQP 0-9-1) message broker emulator",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@rabbitbox/sbi": "0.0.1"
  },
  "keywords": [
    "rabbitmq",
    "amqp",
    "emulator",
    "message-broker",
    "cross-platform"
  ]
}
