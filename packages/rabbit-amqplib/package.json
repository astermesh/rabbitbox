{
  "name": "@rabbitbox/amqplib",
  "version": "0.0.1",
  "description": "amqplib-compatible adapter for RabbitBox in-memory message broker",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@rabbitbox/box": "0.0.1"
  },
  "keywords": [
    "rabbitmq",
    "amqp",
    "amqplib",
    "adapter",
    "in-memory"
  ]
}
